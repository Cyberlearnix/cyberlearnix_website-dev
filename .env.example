# ──────────────────────────────────────────────────────────────────────────────
# .env.example  —  Copy to .env and fill in real values before running
#
#   cp .env.example .env
#
# NEVER commit .env — it is already in .gitignore
# ──────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Shared PostgreSQL superuser password (used for initial DB creation only)
# For production, replace with per-service users after first boot.
POSTGRES_PASSWORD=change-me-strong-password

# DB credentials injected into every service container
DB_USER=postgres
DB_PASS=change-me-strong-password

# ── JWT ───────────────────────────────────────────────────────────────────────
# Must be at least 64 characters for HS512.
# Generate: openssl rand -base64 64
JWT_SECRET=change-me-generate-with-openssl-rand-base64-64

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change-me-redis-password

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the gateway.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Grafana ───────────────────────────────────────────────────────────────────
GF_ADMIN_PASSWORD=change-me-grafana-password

# ── Email ─────────────────────────────────────────────────────────────────────
GMAIL_USER=your-gmail@gmail.com
# Gmail App Password (not your account password): https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=

# ── Resend (alternative transactional email) ──────────────────────────────────
RESEND_API_KEY=

# ── Cloudinary (media uploads) ────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_UPLOAD_PRESET=ml_default
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── PayU (payments) ───────────────────────────────────────────────────────────
PAYU_MERCHANT_KEY=
PAYU_SALT=
PAYU_BASE_URL=https://secure.payu.in

# ── Google Drive (course video/document storage) ────────────────────────────
# 1. Create / rotate service account key in Google Cloud Console
# 2. Base64-encode the downloaded JSON:
#    PowerShell: [Convert]::ToBase64String([IO.File]::ReadAllBytes("key.json")) | clip
#    Linux/Mac:  base64 -w 0 key.json
# 3. Paste the base64 string below
GOOGLE_DRIVE_CREDENTIALS_JSON_B64=
# Drive folder ID (visible in the folder URL: drive.google.com/drive/folders/<FOLDER_ID>)
# Share this folder with the service account email as Editor first.
GOOGLE_DRIVE_FOLDER_ID=

# ── Frontend redirect URL (PayU success/failure) ─────────────────────────
FRONTEND_URL=http://localhost:3000
