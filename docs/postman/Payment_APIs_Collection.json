    {
      "name": "5. PayU Hash Generator (Reference)",
      "description": "Reference for computing PayU hashes manually in Postman using Pre-request Scripts.\n\nCopy the Pre-request Script into a request to auto-compute the hash.",
      "item": [

        {
          "name": "5.1 Initiate Payment + Auto-Hash",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Auto-compute PayU hash for initiate",
                  "// Forward hash: key|txnid|amount|productinfo|firstname|email|udf1|udf2|udf3|udf4|udf5||||||SALT",
                  "",
                  "const key          = 'XidEdD';",
                  "const salt         = '4JPMTxOzkJMchiHLrdFcSgkcXTuzx1Bd';",
                  "const txnid        = pm.variables.get('txnid') || 'TXN-TEST001';",
                  "const amount       = '5000.00';",
                  "const productinfo  = 'Python Bootcamp';",
                  "const firstname    = 'John Doe';",
                  "const email        = 'john@example.com';",
                  "",
                  "// PayU forward hash string",
                  "const hashString = `${key}|${txnid}|${amount}|${productinfo}|${firstname}|${email}|||||||||||${salt}`;",
                  "",
                  "// SHA-512 via CryptoJS (available in Postman sandbox)",
                  "const hash = CryptoJS.SHA512(hashString).toString();",
                  "pm.variables.set('payuHash', hash);",
                  "console.log('PayU Hash:', hash);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl_enrollment}}/api/enrollments/payments/initiate",
              "host": ["{{baseUrl_enrollment}}"],
              "path": ["api", "enrollments", "payments", "initiate"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"formResponseId\": {{formResponseId}},\n  \"studentName\": \"John Doe\",\n  \"studentEmail\": \"john@example.com\",\n  \"studentPhone\": \"9876543210\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "This request has a Pre-request Script that computes the PayU forward hash using CryptoJS.\n\nThe hash is stored in the `payuHash` collection variable after execution.\n\n**PayU Merchant Key:** `XidEdD`\n**PayU Salt:** `4JPMTxOzkJMchiHLrdFcSgkcXTuzx1Bd`"
          },
          "response": []
        },

        {
          "name": "5.2 Reverse Hash Verifier (Webhook/Callback)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Compute PayU reverse hash for callback/webhook verification",
                  "// Format: SALT|status|udf5|udf4|udf3|udf2|udf1|email|firstname|productinfo|amount|txnid|key",
                  "",
                  "const salt        = '4JPMTxOzkJMchiHLrdFcSgkcXTuzx1Bd';",
                  "const key         = 'XidEdD';",
                  "const status      = 'success';",
                  "const txnid       = pm.variables.get('txnid') || 'TXN-TEST001';",
                  "const amount      = '5000.00';",
                  "const productinfo = 'Python Bootcamp';",
                  "const firstname   = 'John Doe';",
                  "const email       = 'john@example.com';",
                  "const udf1='', udf2='', udf3='', udf4='', udf5='';",
                  "",
                  "const hashString = `${salt}|${status}|${udf5}|${udf4}|${udf3}|${udf2}|${udf1}|${email}|${firstname}|${productinfo}|${amount}|${txnid}|${key}`;",
                  "",
                  "const hash = CryptoJS.SHA512(hashString).toString();",
                  "pm.variables.set('payuReverseHash', hash);",
                  "console.log('Reverse Hash:', hash);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl_enrollment}}/api/enrollments/payments/webhook?txnid={{txnid}}&mihpayid=403993715522&mode=CC&status=success&amount=5000.00&productinfo=Python+Bootcamp&firstname=John+Doe&email=john%40example.com&bank_ref_num=1234567890&hash={{payuReverseHash}}",
              "host": ["{{baseUrl_enrollment}}"],
              "path": ["api", "enrollments", "payments", "webhook"],
              "query": [
                { "key": "txnid",       "value": "{{txnid}}" },
                { "key": "mihpayid",    "value": "403993715522" },
                { "key": "mode",        "value": "CC" },
                { "key": "status",      "value": "success" },
                { "key": "amount",      "value": "5000.00" },
                { "key": "productinfo", "value": "Python Bootcamp" },
                { "key": "firstname",   "value": "John Doe" },
                { "key": "email",       "value": "john@example.com" },
                { "key": "bank_ref_num","value": "1234567890" },
                { "key": "hash",        "value": "{{payuReverseHash}}" }
              ]
            },
            "description": "This request auto-computes the PayU reverse hash via Pre-request Script, then sends the webhook with the correct hash.\n\nThis simulates a real PayU server-to-server callback for testing hash verification.\n\n**Run steps:**\n1. Set `txnid` variable to an existing PENDING transaction ID\n2. Send this request\n3. Check the transaction status — it should change to `SUCCESS`"
          },
          "response": []
        }

      ]
    }

