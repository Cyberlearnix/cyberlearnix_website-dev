                                "exec": [
                                    "var jsonData = pm.response.json(); if (jsonData.token) pm.collectionVariables.set(\"jwt_token\", jsonData.token);"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "body": {
                            "mode": "raw",
                            "raw": "{\"email\": \"admin@cyberlearnix.com\", \"password\": \"admin123\"}",
                            "options": {
