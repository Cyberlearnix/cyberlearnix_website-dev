						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{adminToken}}",
									"type": "string"
								}
							]
						},
						"method": "PUT",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"teacherId\": \"SET_TEACHER_ID_HERE\",\n    \"canEditContent\": true,\n    \"canDeleteContent\": false,\n    \"canManageExams\": false\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/api/users/permissions",
							"host": [
