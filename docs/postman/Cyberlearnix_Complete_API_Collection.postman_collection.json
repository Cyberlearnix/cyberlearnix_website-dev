                {
                    "name": "Admin - Forms",
                    "item": [
                        {
                            "name": "List All Forms",
                            "request": {
                                "method": "GET",
                                "header": [
                                    {
                                        "key": "Authorization",
                                        "value": "Bearer {{adminToken}}"
                                    }
                                ],
                                "url": {
                                    "raw": "{{baseUrl}}/api/forms?view=active",
                                    "host": ["{{baseUrl}}"],
                                    "path": ["api", "forms"],
                                    "query": [{"key": "view", "value": "active"}]
