                                    }
                                ],
                                "body": {
                                    "mode": "raw",
                                    "raw": "{\n    \"title\": \"Survey\",\n    \"fields\": \"[]\",\n    \"isActive\": true\n}"
                                },
                                "url": "{{baseUrl}}/api/forms"
                            }
