        {
            "name": "11. Enrollment Form System (LMS)",
            "item": [
                {
                    "name": "Admin: Create Enrollment Form",
                    "request": {
                        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{jwt_token}}", "type": "string" }] },
                        "method": "POST",
                        "body": { "mode": "raw", "raw": "{\"title\": \"Full Stack Bootcamp\", \"courseId\": {{courseId}}, \"fields\": \"[]\"}", "options": { "raw": { "language": "json" } } },
                        "url": { "raw": "{{baseUrl}}/api/enrollments/forms", "host": ["{{baseUrl}}"], "path": ["api", "enrollments", "forms"] }
                    }
                },
                {
                    "name": "Admin: List All Forms",
                    "request": {
                        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{jwt_token}}", "type": "string" }] },
                        "method": "GET",
                        "url": { "raw": "{{baseUrl}}/api/enrollments/forms", "host": ["{{baseUrl}}"], "path": ["api", "enrollments", "forms"] }
                    }
                },
                {
                    "name": "Public: Get Form Config",
                    "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/enrollments/forms/{{formId}}", "host": ["{{baseUrl}}"], "path": ["api", "enrollments", "forms", "{{formId}}"] } }
                },
                {
                    "name": "Public: Submit Enrollment Response",
                    "request": {
                        "method": "POST",
                        "body": { "mode": "raw", "raw": "{\"formId\": \"{{formId}}\", \"studentEmail\": \"student@example.com\", \"studentData\": \"{}\"}", "options": { "raw": { "language": "json" } } },
                        "url": { "raw": "{{baseUrl}}/api/enrollments/responses", "host": ["{{baseUrl}}"], "path": ["api", "enrollments", "responses"] }
                    }
                },
                {
                    "name": "Public: Finalize Payment (Post-PayU)",
                    "request": {
                        "method": "POST",
                        "body": { "mode": "raw", "raw": "{\"transactionId\": \"UTR123456\", \"amount\": 5000}", "options": { "raw": { "language": "json" } } },
                        "url": { "raw": "{{baseUrl}}/api/enrollments/responses/{{enrollmentId}}/finalize", "host": ["{{baseUrl}}"], "path": ["api", "enrollments", "responses", "{{enrollmentId}}", "finalize"] }
                    }
                },
                {
                    "name": "Admin: Toggle Form Active",
                    "request": {
                        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{jwt_token}}", "type": "string" }] },
                        "method": "PATCH",
                        "body": { "mode": "raw", "raw": "{\"active\": true}", "options": { "raw": { "language": "json" } } },
                        "url": { "raw": "{{baseUrl}}/api/enrollments/forms/{{formId}}/active", "host": ["{{baseUrl}}"], "path": ["api", "enrollments", "forms", "{{formId}}", "active"] }
                    }
                }
            ]
        },
        {
            "name": "12. Student Collaboration (Teams)",
            "item": [
                {
                    "name": "List Teams",
                    "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/teams?courseId={{courseId}}", "host": ["{{baseUrl}}"], "path": ["api", "teams"], "query": [{ "key": "courseId", "value": "{{courseId}}" }] } }
