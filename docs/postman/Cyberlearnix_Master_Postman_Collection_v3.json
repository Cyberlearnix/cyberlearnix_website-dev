{
    "info": {
        "_postman_id": "cyberlearnix-master-api-collection-v3",
        "name": "Cyberlearnix Master API Suite v3",
        "description": "Comprehensive Master Collection for all Cyberlearnix Microservices. Covers 35+ Controllers across 7 services. 100% Coverage of Authentication, User Management, Course/LMS, Enrollment, Payments, Forms, Notifications, and Shop.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "01. Auth & Identity",
            "item": [
                {
                    "name": "Login",
                    "event": [
                        {
                            "listen": "test",
                            "script": { "exec": ["var jsonData = pm.response.json(); if (jsonData.token) pm.collectionVariables.set(\"jwt_token\", jsonData.token);"], "type": "text/javascript" }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "body": { "mode": "raw", "raw": "{\"email\": \"shivakumar@cyberlearnix.com\", \"password\": \"Shivam$179\"}", "options": { "raw": { "language": "json" } } },
                        "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] }
                    }
                },
                {
                    "name": "Register",
                    "request": {
                        "method": "POST",
                        "body": { "mode": "raw", "raw": "{\"email\": \"user@example.com\", \"password\": \"password123\", \"role\": \"student\", \"fullName\": \"John Doe\"}", "options": { "raw": { "language": "json" } } },
                        "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "auth", "register"] }
                    }
                },
                {
                    "name": "Request OTP",
                    "request": {
                        "method": "POST",
                        "body": { "mode": "raw", "raw": "{\"email\": \"user@example.com\"}", "options": { "raw": { "language": "json" } } },
                        "url": { "raw": "{{baseUrl}}/api/auth/request-otp", "host": ["{{baseUrl}}"], "path": ["api", "auth", "request-otp"] }
                    }
                },
                {
                    "name": "Verify OTP (Reset Password)",
                    "request": {
                        "method": "POST",
                        "body": { "mode": "raw", "raw": "{\"email\": \"user@example.com\", \"otp\": \"123456\", \"newPassword\": \"newSecurePass123!\"}", "options": { "raw": { "language": "json" } } },
                        "url": { "raw": "{{baseUrl}}/api/auth/verify-otp", "host": ["{{baseUrl}}"], "path": ["api", "auth", "verify-otp"] }
                    }
                },
                {
                    "name": "Switch Role",
                    "request": {
                        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{jwt_token}}", "type": "string" }] },
                        "method": "POST",
                        "body": { "mode": "raw", "raw": "{\"role\": \"teacher\"}", "options": { "raw": { "language": "json" } } },
                        "url": { "raw": "{{baseUrl}}/api/auth/switch-role", "host": ["{{baseUrl}}"], "path": ["api", "auth", "switch-role"] }
                    }
                }
            ]
        },
        {
            "name": "02. User Management",
            "item": [
                {
                    "name": "List All Users",
                    "request": {
                        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{jwt_token}}", "type": "string" }] },
                        "method": "GET",
                        "url": { "raw": "{{baseUrl}}/api/users", "host": ["{{baseUrl}}"], "path": ["api", "users"] }
                    }
                },
                {
                    "name": "Get My Profile",
                    "request": {
                        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{jwt_token}}", "type": "string" }] },
                        "method": "GET",
                        "url": { "raw": "{{baseUrl}}/api/users/profile", "host": ["{{baseUrl}}"], "path": ["api", "users", "profile"] }
                    }
                },
                {
                    "name": "Update Profile",
                    "request": {
                        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{jwt_token}}", "type": "string" }] },
                        "method": "PUT",
                        "body": { "mode": "raw", "raw": "{\"fullName\": \"Updated Name\", \"phone\": \"9876543210\", \"bio\": \"LMS Admin\"}", "options": { "raw": { "language": "json" } } },
                        "url": { "raw": "{{baseUrl}}/api/users/profile", "host": ["{{baseUrl}}"], "path": ["api", "users", "profile"] }
                    }
                },
                {
                    "name": "Get Activity Logs",
                    "request": {
                        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{jwt_token}}", "type": "string" }] },
                        "method": "GET",
                        "url": { "raw": "{{baseUrl}}/api/activity/logs/{{userId}}?limit=50", "host": ["{{baseUrl}}"], "path": ["api", "activity", "logs", "{{userId}}"], "query": [{ "key": "limit", "value": "50" }] }
                    }
                }
            ]
        },
        {
            "name": "03. Course Catalog",
            "item": [
                {
                    "name": "List Courses (Public/Standard)",
                    "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/courses", "host": ["{{baseUrl}}"], "path": ["api", "courses"] } }
                },
                {
                    "name": "Get Curriculum",
                    "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/courses/{{courseId}}/curriculum", "host": ["{{baseUrl}}"], "path": ["api", "courses", "{{courseId}}", "curriculum"] } }
                },
                {
                    "name": "Get Course Updates",
                    "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/updates/course/{{courseId}}", "host": ["{{baseUrl}}"], "path": ["api", "updates", "course", "{{courseId}}"] } }
                }
            ]
        },
        {
            "name": "04. LMS & Student Experience",
            "item": [
                {
                    "name": "Get My Progress",
                    "request": {
                        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{jwt_token}}", "type": "string" }] },
                        "method": "GET",
                        "url": { "raw": "{{baseUrl}}/api/courses/progress/{{courseId}}", "host": ["{{baseUrl}}"], "path": ["api", "courses", "progress", "{{courseId}}"] }
                    }
                },
                {
                    "name": "Update Progress",
                    "request": {
                        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{jwt_token}}", "type": "string" }] },
                        "method": "POST",
                        "body": { "mode": "raw", "raw": "{\"contentId\": \"{{contentId}}\", \"status\": \"COMPLETED\", \"videoTime\": 450}", "options": { "raw": { "language": "json" } } },
                        "url": { "raw": "{{baseUrl}}/api/courses/progress/update", "host": ["{{baseUrl}}"], "path": ["api", "courses", "progress", "update"] }
                    }
                },
                {
                    "name": "Generate Certificate",
                    "request": {
                        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{jwt_token}}", "type": "string" }] },
                        "method": "GET",
                        "url": { "raw": "{{baseUrl}}/api/certificates/generate/{{enrollmentId}}", "host": ["{{baseUrl}}"], "path": ["api", "certificates", "generate", "{{enrollmentId}}"] }
                    }
                }
            ]
        },
        {
            "name": "05. Admin: Course Management",
            "item": [
                {
                    "name": "Create Course",
                    "request": {
                        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{jwt_token}}", "type": "string" }] },
                        "method": "POST",
                        "body": { "mode": "raw", "raw": "{\"title\": \"New Course\", \"slug\": \"new-course\", \"description\": \"Desc\", \"basePrice\": 4999.0, \"gstPercent\": 18, \"category\": \"Cybersecurity\"}", "options": { "raw": { "language": "json" } } },
                        "url": { "raw": "{{baseUrl}}/api/course-management/courses", "host": ["{{baseUrl}}"], "path": ["api", "course-management", "courses"] }
                    }
                },
                {
                    "name": "Update Course",
                    "request": {
                        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{jwt_token}}", "type": "string" }] },
                        "method": "PUT",
                        "body": { "mode": "raw", "raw": "{\"title\": \"Updated Course Title\", \"basePrice\": 5500.0, \"gstPercent\": 18}", "options": { "raw": { "language": "json" } } },
                        "url": { "raw": "{{baseUrl}}/api/course-management/courses/{{courseId}}", "host": ["{{baseUrl}}"], "path": ["api", "course-management", "courses", "{{courseId}}"] }
                    }
                },
                {
                    "name": "Add Module",
                    "request": {
                        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{jwt_token}}", "type": "string" }] },
                        "method": "POST",
                        "body": { "mode": "raw", "raw": "{\"title\": \"Module 1\", \"displayOrder\": 1}", "options": { "raw": { "language": "json" } } },
                        "url": { "raw": "{{baseUrl}}/api/course-management/courses/{{courseId}}/modules", "host": ["{{baseUrl}}"], "path": ["api", "course-management", "courses", "{{courseId}}", "modules"] }
                    }
                },
                {
                    "name": "Add Content",
                    "request": {
                        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{jwt_token}}", "type": "string" }] },
                        "method": "POST",
                        "body": { "mode": "raw", "raw": "{\"title\": \"Lesson 1\", \"contentType\": \"VIDEO\", \"videoUrl\": \"https://vid.com\"}", "options": { "raw": { "language": "json" } } },
                        "url": { "raw": "{{baseUrl}}/api/course-management/modules/{{moduleId}}/contents", "host": ["{{baseUrl}}"], "path": ["api", "course-management", "modules", "{{moduleId}}", "contents"] }
                    }
                }
            ]
        },
        {
            "name": "06. Enrollment & Payments",
            "item": [
                {
                    "name": "Get All Enrollments (Admin)",
                    "request": {
                        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{jwt_token}}", "type": "string" }] },
                        "method": "GET",
                        "url": { "raw": "{{baseUrl}}/api/enrollments", "host": ["{{baseUrl}}"], "path": ["api", "enrollments"] }
                    }
                },
                {
                    "name": "Bulk Assign Students (Admin)",
                    "request": {
                        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{jwt_token}}", "type": "string" }] },
                        "method": "POST",
                        "body": { "mode": "raw", "raw": "{\"userId\": \"{{userId}}\", \"courseIds\": [1, 2, 3]}", "options": { "raw": { "language": "json" } } },
                        "url": { "raw": "{{baseUrl}}/api/enrollments/bulk-assign", "host": ["{{baseUrl}}"], "path": ["api", "enrollments", "bulk-assign"] }
                    }
                },
                {
                    "name": "Initiate PayU Payment",
                    "request": {
                        "method": "POST",
                        "body": { "mode": "raw", "raw": "{\"amount\": 100, \"courseName\": \"Ethical Hacking\", \"studentName\": \"John\", \"studentEmail\": \"john@example.com\", \"studentPhone\": \"1234567890\", \"courseId\": {{courseId}}, \"formId\": \"{{formId}}\", \"enrollmentFormResponseId\": {{enrollmentId}}}", "options": { "raw": { "language": "json" } } },
                        "url": { "raw": "{{baseUrl}}/api/payu-payment", "host": ["{{baseUrl}}"], "path": ["api", "payu-payment"] }
                    }
                },
                {
                    "name": "Verify Payment (Admin)",
                    "request": {
                        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{jwt_token}}", "type": "string" }] },
                        "method": "POST",
                        "body": { "mode": "raw", "raw": "{\"enrollmentId\": {{enrollmentId}}, \"action\": \"VERIFY\", \"rejectionReason\": \"\"}", "options": { "raw": { "language": "json" } } },
                        "url": { "raw": "{{baseUrl}}/api/enrollments/verify-payment", "host": ["{{baseUrl}}"], "path": ["api", "enrollments", "verify-payment"] }
                    }
                }
            ]
        },
        {
            "name": "07. Universal Form Service (Public/General)",
            "item": [
                {
                    "name": "Get Form Config (Public)",
                    "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/forms/{{formId}}", "host": ["{{baseUrl}}"], "path": ["api", "forms", "{{formId}}"] } }
                },
                {
                    "name": "Check Response Status",
                    "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/forms/{{formId}}/responses/check?email=user@example.com", "host": ["{{baseUrl}}"], "path": ["api", "forms", "{{formId}}", "responses", "check"], "query": [{ "key": "email", "value": "user@example.com" }] } }
                },
                {
                    "name": "Submit Form Response (Public)",
                    "request": {
                        "method": "POST",
                        "body": { "mode": "raw", "raw": "{\"userEmail\": \"user@example.com\", \"submissionData\": {\"fieldName\": \"Value\"}}", "options": { "raw": { "language": "json" } } },
                        "url": { "raw": "{{baseUrl}}/api/forms/{{formId}}/responses", "host": ["{{baseUrl}}"], "path": ["api", "forms", "{{formId}}", "responses"] }
                    }
                },
                {
                    "name": "Admin: List All Forms",
                    "request": {
                        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{jwt_token}}", "type": "string" }] },
                        "method": "GET",
                        "url": { "raw": "{{baseUrl}}/api/forms", "host": ["{{baseUrl}}"], "path": ["api", "forms"] }
                    }
                },
                {
                    "name": "Admin: Export Responses to CSV",
                    "request": {
                        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{jwt_token}}", "type": "string" }] },
                        "method": "GET",
                        "url": { "raw": "{{baseUrl}}/api/forms/{{formId}}/responses/export", "host": ["{{baseUrl}}"], "path": ["api", "forms", "{{formId}}", "responses", "export"] }
                    }
                }
            ]
        },
        {
            "name": "08. Media & Content CMS",
            "item": [
                {
                    "name": "Upload Media (Image/Video/Doc)",
                    "request": {
                        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{jwt_token}}", "type": "string" }] },
                        "method": "POST",
                        "body": { "mode": "formdata", "formdata": [{ "key": "file", "type": "file", "src": "" }] },
                        "url": { "raw": "{{baseUrl}}/api/materials/upload/thumbnail", "host": ["{{baseUrl}}"], "path": ["api", "materials", "upload", "thumbnail"] }
