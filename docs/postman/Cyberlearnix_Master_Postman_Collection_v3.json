                    "name": "Get Promo Popups",
                    "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/promos", "host": ["{{baseUrl}}"], "path": ["api", "promos"] } }
                }
            ]
        },
        {
            "name": "09. Communications & Notifications",
            "item": [
                {
                    "name": "Broadcast Alert (Admin)",
                    "request": {
                        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{jwt_token}}", "type": "string" }] },
                        "method": "POST",
                        "body": { "mode": "raw", "raw": "{\"emails\":[\"u1@test.com\"], \"subject\":\"Update\", \"message\":\"Hi\"}", "options": { "raw": { "language": "json" } } },
                        "url": { "raw": "{{baseUrl}}/api/notifications?action=broadcast", "host": ["{{baseUrl}}"], "path": ["api", "notifications"], "query": [{ "key": "action", "value": "broadcast" }] }
                    }
                },
                {
                    "name": "Submit Contact Form",
                    "request": {
                        "method": "POST",
                        "body": { "mode": "raw", "raw": "{\"name\": \"Inquirer\", \"email\": \"i@i.com\", \"message\": \"Help\"}", "options": { "raw": { "language": "json" } } },
                        "url": { "raw": "{{baseUrl}}/api/contact-submissions", "host": ["{{baseUrl}}"], "path": ["api", "contact-submissions"] }
                    }
                }
            ]
        },
        {
            "name": "10. Shop & Internal Tools",
            "item": [
                {
                    "name": "Get Shop Info",
                    "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/shop", "host": ["{{baseUrl}}"], "path": ["api", "shop"] } }
                },
                {
                    "name": "Site Settings",
                    "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/site-settings", "host": ["{{baseUrl}}"], "path": ["api", "site-settings"] } }
                },
                {
                    "name": "Get Navigation Menus",
                    "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/menus?location=header", "host": ["{{baseUrl}}"], "path": ["api", "menus"], "query": [{ "key": "location", "value": "header" }] } }
                }
            ]
