VITE_SUPABASE_URL=YOUR_SUPABASE_URL
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Cloudinary
VITE_CLOUDINARY_CLOUD_NAME=YOUR_CLOUD_NAME
VITE_CLOUDINARY_UPLOAD_PRESET=YOUR_UPLOAD_PRESET

# Email Service (Resend)
RESEND_API_KEY=re_123456789

# Database (PostgreSQL / Supabase)
DB_HOST=aws-0-ap-south-1.pooler.supabase.com
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres.xxxxxxxxxxxx
DB_PASSWORD=your_database_password

# ─── Google Drive Upload ──────────────────────────────────────────────────────
# Paste the ENTIRE contents of your service account JSON file as a single line.
# Leave the \n sequences in private_key as-is (do NOT expand them to real newlines).
# Example: GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"my-project",...}
GOOGLE_SERVICE_ACCOUNT_JSON=

# Optional: ID of an existing folder to use as root in Google Drive.
# If blank, a folder called "CyberLearnix" is auto-created at Drive root.
# Find it in the URL when you open the folder: drive.google.com/drive/folders/<ID>
GOOGLE_DRIVE_ROOT_FOLDER_ID=
